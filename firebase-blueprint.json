{
  "entities": {
    "WorkLog": {
      "title": "Work Log",
      "description": "A daily record of work hours.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase Auth UID of the owner."
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "The date of the work record (YYYY-MM-DD)."
        },
        "start": {
          "type": "string",
          "description": "Start time (HH:mm)."
        },
        "end": {
          "type": "string",
          "description": "End time (HH:mm)."
        },
        "total": {
          "type": "number",
          "description": "Total hours calculated."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp."
        }
      },
      "required": ["uid", "date", "start", "end", "total", "createdAt"]
    }
  },
  "firestore": {
    "/logs/{logId}": {
      "schema": "WorkLog",
      "description": "Collection of work logs for all users."
    }
  }
}
